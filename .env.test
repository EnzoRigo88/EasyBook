# ── LLM Provider ────────────────────────────────────────────────────────────
# "mock"   → scripted responses, no network (default for local dev)
# "ollama" → local Ollama container (free, real model, ~2 GB)
# "openai" → real OpenAI API (requires OPENAI_API_KEY below)
LLM_PROVIDER=mock

# Required only when LLM_PROVIDER=openai
OPENAI_API_KEY=

# Required only when LLM_PROVIDER=ollama (default points to Docker service)
OLLAMA_BASE_URL=http://ollama:11434/v1

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://easybook:easybook_dev@localhost:5432/easybook

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=dev-jwt-secret-change-in-production-32c
JWT_REFRESH_SECRET=

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
ENV=development

# ── WhatsApp — Meta Cloud API (production) ───────────────────────────────────
META_WA_PHONE_NUMBER_ID=
META_WA_ACCESS_TOKEN=
META_WA_WEBHOOK_VERIFY_TOKEN=dev-verify-token

# ── WhatsApp — Twilio (Phase 1 / sandbox) ────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WA_NUMBER=

# ── n8n ──────────────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=http://localhost:5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin123

# ── Mercado Pago (Phase 3) ────────────────────────────────────────────────────
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# ── Infrastructure ────────────────────────────────────────────────────────────
HETZNER_TOKEN=
SENTRY_DSN=
